        "import math\n",
        "\n",
        "def equacao2grau(a, b, c):\n",
        "  delta = b**2 - 4*a*c\n",
        "\n",
        "  if (delta < 0 ):\n",
        "    return 'numero sem raiz', delta\n",
        "\n",
        "  x1 = (-b + math.sqrt(delta))/ (2*a)\n",
        "  x2 = (-b - math.sqrt(delta))/ (2*a)\n",
        "\n",
        "  return x1 , x2"
      ],
